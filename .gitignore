# Build output
bin/
obj/
publish/

# Visual Studio
.vs/
*.user
*.suo

# Diagnostic / runtime files written by the emulator
pit_writes.txt
pc_hist.txt
dump.txt
dump.txt.trace
*.trace

# User-customised keymap (regenerated from defaults if missing)
keymap.json

# User preferences (regenerated with defaults if missing)
settings.ini

# Local convenience scripts
resumeproject.bat

# other files
.claude/

# User-supplied ROM / BASIC images (Sharp Corp. copyright — not shipped)
roms/*.rom
roms/*.int
roms/*.txt
basic/*.mzf

# Commercial cassette images — put your own here, they will not be tracked
games/*.mzf
games/*.m12
games/*.mzt
games/*.zip
!games/joytest.mzf