# Build output
bin/
obj/
publish/
publish-*/
MZ700Emul-*.zip

# Visual Studio
.vs/
*.user
*.suo

# Diagnostic / runtime files written by the emulator
dump.txt
dump.txt.trace
*.trace
ram-*.txt

# Local archive form of tools (committed extracted)
tools/CPM.zip

# User-customised keymap (regenerated from defaults if missing)
keymap.json

# User preferences (regenerated with defaults if missing)
settings.ini

# Local convenience scripts
resumeproject.bat

# Local working dirs — convention: any folder prefixed with '_' is
# local-only (session artifacts, scratch dumps, downloaded reference
# material). Never committed.
_*/

# other files
.claude/

# User-supplied ROM / BASIC images (Sharp Corp. copyright — not shipped)
roms/*.rom
roms/*.int
roms/*.txt
basic/*.mzf

# Commercial cassette images — put your own here, they will not be tracked
games/*.mzf
games/*.m12
games/*.mzt
games/*.zip
!games/joytest.mzf